# =============================================================================
# API Testing Framework — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Target API ---
API_BASE_URL=https://restful-booker.herokuapp.com
API_VERSION=v1

# --- Authentication ---
# Injected at runtime; never hardcoded. In CI, these come from GitHub Secrets.
API_USERNAME=admin
API_PASSWORD=password123
API_TOKEN=

# --- TLS / SSL ---
# Absolute path to a CA bundle for strict SSL verification.
# Leave blank to use system defaults (certifi).
SSL_CA_BUNDLE=

# --- Timeouts (seconds) ---
REQUEST_CONNECT_TIMEOUT=5
REQUEST_READ_TIMEOUT=15

# --- Retry Policy ---
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_MAX_DELAY_SECONDS=30.0

# --- SLO Enforcement ---
# Hard-fail any response exceeding this threshold (milliseconds)
SLO_RESPONSE_TIME_MS=3000

# --- Circuit Breaker ---
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60

# --- Observability ---
LOG_LEVEL=INFO
LOG_FILE=logs/test_run.jsonl

# --- Redis (required for pytest-xdist parallel execution) ---
# Leave blank for single-process runs. Set for -n auto / -n <N> parallel runs.
# When using docker-compose, this is automatically set to the redis service.
REDIS_URL=redis://localhost:6379/0
